# Normalize line endings for all text files
* text=auto

# Force LF for source files
*.js    text eol=lf
*.jsx   text eol=lf
*.ts    text eol=lf
*.tsx   text eol=lf
*.json  text eol=lf
*.html  text eol=lf
*.css   text eol=lf
*.md    text eol=lf

# Binary files — no conversion
*.png   binary
*.jpg   binary
*.ico   binary
*.woff  binary
*.woff2 binary
